generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH ====================

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String?
  role           UserRole @default(ADMIN)
  phone          String?
  color          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  jobs             Job[]         @relation("AssignedJobs")
  notes            Note[]
  assignedRequests Request[]     @relation("AssignedRequests")
  timeEntries      TimeEntry[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum UserRole {
  ADMIN
  CLEANER
}

// ==================== CRM ====================

model Customer {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String
  address   String
  city      String
  postcode  String
  latitude  Float?
  longitude Float?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]
  quotes     Quote[]
  jobs       Job[]
  invoices   Invoice[]
  notes      Note[]
  requests   Request[]

  @@index([lastName, firstName])
  @@index([postcode])
  @@map("customers")
}

model Property {
  id           String   @id @default(cuid())
  customerId   String
  address      String
  city         String
  postcode     String
  latitude     Float?
  longitude    Float?
  propertyType String?
  rooms        Int?
  sqFootage    Float?
  carpetTypes  String[]
  accessNotes  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobs     Job[]

  @@index([customerId])
  @@map("properties")
}

// ==================== SERVICE CATALOG ====================

model Service {
  id          String  @id @default(cuid())
  name        String
  description String?
  unitPrice   Float
  unit        String
  category    String
  isActive    Boolean @default(true)

  quoteLineItems QuoteLineItem[]
  jobLineItems   JobLineItem[]

  @@map("services")
}

// ==================== QUOTING ====================

model Quote {
  id          String      @id @default(cuid())
  quoteNumber String      @unique
  customerId  String
  status      QuoteStatus @default(DRAFT)
  subtotal    Float       @default(0)
  taxRate     Float       @default(20)
  taxAmount   Float       @default(0)
  total       Float       @default(0)
  notes       String?
  validUntil  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer  Customer        @relation(fields: [customerId], references: [id])
  lineItems QuoteLineItem[]
  job       Job?

  @@index([customerId])
  @@index([status])
  @@map("quotes")
}

model QuoteLineItem {
  id          String @id @default(cuid())
  quoteId     String
  serviceId   String
  description String
  quantity    Int    @default(1)
  unitPrice   Float
  total       Float

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([quoteId])
  @@map("quote_line_items")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  CONVERTED
}

// ==================== JOBS ====================

model Job {
  id            String    @id @default(cuid())
  jobNumber     String    @unique
  customerId    String
  propertyId    String?
  quoteId       String?   @unique
  assignedToId  String?
  status        JobStatus @default(SCHEDULED)
  scheduledDate DateTime
  scheduledTime String?
  duration      Int       @default(60)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer    Customer      @relation(fields: [customerId], references: [id])
  property    Property?     @relation(fields: [propertyId], references: [id])
  quote       Quote?        @relation(fields: [quoteId], references: [id])
  assignedTo  User?         @relation("AssignedJobs", fields: [assignedToId], references: [id])
  lineItems    JobLineItem[]
  invoice      Invoice?
  timeEntries  TimeEntry[]
  smsReminders SmsReminder[]

  @@index([customerId])
  @@index([scheduledDate])
  @@index([assignedToId, scheduledDate])
  @@index([status])
  @@map("jobs")
}

model JobLineItem {
  id          String @id @default(cuid())
  jobId       String
  serviceId   String
  description String
  quantity    Int    @default(1)
  unitPrice   Float
  total       Float

  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([jobId])
  @@map("job_line_items")
}

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  INVOICED
}

// ==================== INVOICING ====================

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  jobId         String        @unique
  customerId    String
  status        InvoiceStatus @default(UNPAID)
  subtotal      Float
  taxRate       Float         @default(20)
  taxAmount     Float
  total         Float
  amountPaid    Float         @default(0)
  dueDate       DateTime
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  job      Job       @relation(fields: [jobId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  payments Payment[]

  @@index([customerId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  VOID
}

// ==================== PAYMENTS ====================

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String
  amount          Float
  method          PaymentMethod
  stripePaymentId String?       @unique
  stripeCheckoutId String?
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([stripePaymentId])
  @@map("payments")
}

enum PaymentMethod {
  CARD
  KLARNA
  CASH
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ==================== NOTES ====================

model Note {
  id         String   @id @default(cuid())
  customerId String
  authorId   String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@index([customerId])
  @@map("notes")
}

// ==================== REQUESTS/LEADS ====================

model Request {
  id           String          @id @default(cuid())
  source       RequestSource   @default(PHONE)
  firstName    String
  lastName     String
  email        String?
  phone        String
  address      String?
  city         String?
  postcode     String?
  description  String          @db.Text
  status       RequestStatus   @default(NEW)
  priority     RequestPriority @default(MEDIUM)
  notes        String?         @db.Text
  customerId   String?
  assignedToId String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  customer   Customer? @relation(fields: [customerId], references: [id])
  assignedTo User?     @relation("AssignedRequests", fields: [assignedToId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("requests")
}

enum RequestSource {
  WEBSITE
  PHONE
  EMAIL
  REFERRAL
  OTHER
}

enum RequestStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
}

// ==================== TIME TRACKING ====================

model TimeEntry {
  id        String    @id @default(cuid())
  userId    String
  jobId     String?
  clockIn   DateTime
  clockOut  DateTime?
  duration  Int?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
  job  Job? @relation(fields: [jobId], references: [id])

  @@index([userId, clockIn])
  @@index([jobId])
  @@map("time_entries")
}

// ==================== COMPANY SETTINGS ====================

model CompanySettings {
  id             String @id @default("default")
  companyName    String @default("CleanPro")
  address        String?
  city           String?
  postcode       String?
  phone          String?
  email          String?
  website        String?
  vatNumber      String?
  logoUrl        String?
  defaultTaxRate Float  @default(20)
  invoicePrefix  String @default("INV")
  quotePrefix    String @default("QUO")
  jobPrefix      String @default("JOB")
  invoiceTerms   String? @db.Text
  quoteTerms     String? @db.Text

  @@map("company_settings")
}

// ==================== SMS REMINDERS ====================

model SmsReminder {
  id        String         @id @default(cuid())
  jobId     String
  type      SmsReminderType
  phone     String
  message   String         @db.Text
  status    SmsStatus      @default(PENDING)
  twilioSid String?
  error     String?
  sentAt    DateTime?
  createdAt DateTime       @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, type])
  @@index([status])
  @@index([createdAt])
  @@map("sms_reminders")
}

enum SmsReminderType {
  REMINDER_24H_BEFORE
  REVIEW_24H_AFTER
}

enum SmsStatus {
  PENDING
  SENT
  FAILED
}

// ==================== SEQUENCE COUNTER ====================

model Sequence {
  id      String @id
  current Int    @default(0)

  @@map("sequences")
}
